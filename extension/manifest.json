{
  "manifest_version": 3,
  "name": "NomFeed",
  "version": "1.0.0",
  "description": "Nom the web. Feed your agents. Convert any page to markdown for AI agents.",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page-deck.js", "page-annotator.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "annotate-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+N",
        "mac": "Command+Shift+N"
      },
      "description": "Start NomFeed annotation on the current page"
    }
  }
}
