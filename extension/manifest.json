{
  "manifest_version": 3,
  "name": "NomFeed",
  "version": "1.0.0",
  "description": "Save any page to NomFeed — convert to markdown for AI agents",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
